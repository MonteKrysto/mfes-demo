{
  "name": "franks-sides",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n franks-sides-ui,franks-sides-api -c red,blue \"vite --host 0.0.0.0 --port 5177\" \"tsx watch src/server/index.ts\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:ui": "vite --host 0.0.0.0 --port 5177",
    "dev:standalone": "pnpm dev",
    "build": "tsc -b && vite build",
    "build:standalone": "tsc -b && vite build",
    "preview": "concurrently -n franks-sides-preview,franks-sides-api -c red,blue \"vite preview --host 0.0.0.0 --port 5177\" \"tsx src/server/index.ts\"",
    "preview:ui": "vite preview --host 0.0.0.0 --port 5177",
    "preview:standalone": "pnpm preview",
    "build-and-preview:ui": "pnpm build && pnpm preview:ui",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "contract:test": "vitest run src/server/contract.test.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
