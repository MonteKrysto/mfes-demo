FROM node:22-bookworm-slim

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

RUN corepack enable && corepack prepare pnpm@9.12.1 --activate

WORKDIR /workspace

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/host/package.json apps/host/package.json
COPY apps/frodos-franks/package.json apps/frodos-franks/package.json
COPY apps/boromirs-burgers/package.json apps/boromirs-burgers/package.json
COPY apps/franks-sides/package.json apps/franks-sides/package.json
COPY apps/burgers-sauces/package.json apps/burgers-sauces/package.json
COPY apps/deployment/package.json apps/deployment/package.json

RUN pnpm install --frozen-lockfile

COPY . .

CMD ["pnpm", "dev"]
